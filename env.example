# ─── Google Apps Script ───────────────────────────────────────
VITE_SCRIPT_URL=https://script.google.com/macros/s/XXXXXX/exec
VITE_TOKEN=TuTokenSecreto2024

# ─── Identidad del negocio ────────────────────────────────────
# La pestaña del navegador mostrará: "🌸 Salomé Zuluaga"
# ⚠️  VITE_BIZ_NAME no debe incluir el emoji — va separado en VITE_BIZ_EMOJI
VITE_BIZ_NAME=Salomé Zuluaga
VITE_BIZ_SUBTITLE=Micropigmentación
VITE_BIZ_EMOJI=🌸

# URL pública de la imagen del logo (jpg, png, webp…)
# Sin logo → se usa el emoji en el header y como favicon.
# Con logo → la imagen reemplaza el emoji en el header y en la pestaña.
VITE_BIZ_LOGO=https://ejemplo.com/logo.png
